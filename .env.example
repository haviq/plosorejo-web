# Environment template — copy to Vercel Project Settings (never commit real secrets)

# Sanity (public project id is fine; write token is SECRET)
NEXT_PUBLIC_SANITY_PROJECT_ID=p7xgykwm
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Required for /api/cron/* in production (min 16 chars).
# Generate: openssl rand -hex 24
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> when configured.
# CRON_SECRET=

# Optional write token for seed script only (local). NEVER expose to browser.
# SANITY_API_WRITE_TOKEN=

# Admin panel PIN for /admin (min 4 chars recommended 8+). Cookie session 12h.
# Exact name: ADMIN_PIN  (also accepts ADMIN_PIN_CODE / PLOSOREJO_ADMIN_PIN)
# Vercel: Project → Settings → Environment Variables → Production + Preview
# After save you MUST Redeploy for the value to apply.
# ADMIN_PIN=
